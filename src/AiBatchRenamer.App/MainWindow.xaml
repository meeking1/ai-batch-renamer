<Window x:Class="AiBatchRenamer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI批量重命名 for Selena by Dogdog v0.1.9" Height="720" Width="1180" MinHeight="620" MinWidth="980"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{StaticResource Brush.Page}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1" Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="34" Height="34" Background="{StaticResource Brush.Primary}" CornerRadius="8" Margin="0,0,12,0">
                        <TextBlock Text="AI" Foreground="#FFFFFF" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="AI批量重命名 for Selena by Dogdog v0.1.9" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}" />
                        <TextBlock Text="预览确认后直接在原文件上改名；冲突和未变化项会自动跳过。" Style="{StaticResource MutedText}" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Background="{StaticResource Brush.PrimarySoft}" BorderBrush="#C9DAFF" BorderThickness="1" CornerRadius="14" Padding="12,5" VerticalAlignment="Center">
                    <TextBlock Foreground="{StaticResource Brush.Primary}" FontWeight="SemiBold" Text="{Binding ElementName=MainWindowStatus, Path=Text}" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,0,12">
                    <DockPanel LastChildFill="False">
                        <WrapPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <Button Content="添加文件" Click="AddFiles_Click" />
                            <Button Content="添加文件夹" Click="AddFolder_Click" />
                            <Button Content="移除选中" Click="RemoveSelected_Click" />
                            <Button Content="上移" Click="MoveSelectedUp_Click" />
                            <Button Content="下移" Click="MoveSelectedDown_Click" />
                            <Button Content="定位文件" Click="RevealSelected_Click" />
                            <Button Content="复制预览" Click="CopyPreview_Click" />
                            <Button Content="导出预览" Click="ExportPreview_Click" />
                            <Button Content="打开日志" Click="OpenLogs_Click" />
                            <Button Content="清空" Click="Clear_Click" />
                            <Button Content="撤销上次操作" Click="Undo_Click" />
                        </WrapPanel>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="1">
                    <DataGrid x:Name="FilesGrid" ItemsSource="{Binding Items}"
                              AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                              SelectionMode="Extended" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="54" IsReadOnly="True" />
                            <DataGridTextColumn Header="原文件名" Binding="{Binding OriginalName}" Width="2*" IsReadOnly="True" />
                            <DataGridTextColumn Header="新文件名预览" Binding="{Binding ProposedBaseName, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                            <DataGridTextColumn Header="扩展后名称" Binding="{Binding ProposedName}" Width="2*" IsReadOnly="True" />
                            <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90" IsReadOnly="True" />
                            <DataGridTextColumn Header="说明" Binding="{Binding Message}" Width="210" IsReadOnly="True" />
                            <DataGridTemplateColumn Header="" Width="52" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="×"
                                                Style="{StaticResource RowDeleteButton}"
                                                Click="RemoveRow_Click"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <Border Grid.Column="1" Margin="14,0,0,0" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="重命名设置" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}" Margin="0,0,0,12" />

                        <TextBlock Text="重命名模式" Style="{StaticResource SectionTitle}" />
                        <ComboBox x:Name="ModeComboBox" SelectedIndex="0">
                            <ComboBoxItem Content="自然语言规则" />
                            <ComboBoxItem Content="多名称逐行替换" />
                            <ComboBoxItem Content="查找替换" />
                            <ComboBoxItem Content="模板命名" />
                        </ComboBox>

                        <CheckBox x:Name="SanitizeCheckBox" Content="自动替换非法字符" IsChecked="True" />
                        <CheckBox x:Name="RecursiveFolderCheckBox" Content="添加文件夹时包含子文件夹" IsChecked="False" />

                        <TextBlock Text="排序方式" Style="{StaticResource SectionTitle}" />
                        <ComboBox x:Name="SortComboBox" SelectedIndex="0">
                            <ComboBoxItem Content="文件名 A-Z" />
                            <ComboBoxItem Content="文件名 Z-A" />
                            <ComboBoxItem Content="修改时间 旧-新" />
                            <ComboBoxItem Content="修改时间 新-旧" />
                            <ComboBoxItem Content="文件大小 小-大" />
                            <ComboBoxItem Content="文件大小 大-小" />
                        </ComboBox>
                        <Button Content="应用排序" Click="ApplySort_Click" />

                        <Separator Margin="0,6,0,14" />

                        <TextBlock Text="查找替换" Style="{StaticResource SectionTitle}" />
                        <TextBox x:Name="FindTextBox" ToolTip="查找替换模式下使用" />
                        <TextBox x:Name="ReplaceTextBox" ToolTip="查找替换模式下使用" />

                        <TextBlock Text="命名要求 / 名称列表" Style="{StaticResource SectionTitle}" />
                        <TextBox x:Name="InstructionTextBox" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" MinHeight="210"
                                 ToolTip="自然语言示例：命名为“项目资料”。多名称模式下每行一个新名称。模板示例：{name}-{index:000}" />

                        <Button Content="生成预览" Click="Preview_Click" Style="{StaticResource PrimaryButton}" Margin="0,2,0,10" />
                        <Button Content="确认重命名" Click="Execute_Click" Style="{StaticResource PrimaryButton}" Margin="0,0,0,14" />

                        <Separator Margin="0,4,0,14" />

                        <TextBlock Text="操作历史" Style="{StaticResource SectionTitle}" />
                        <ComboBox x:Name="OperationHistoryComboBox" DisplayMemberPath="DisplayText" />
                        <Button Content="刷新历史" Click="RefreshHistory_Click" />
                        <Button Content="撤销选中历史" Click="UndoSelectedHistory_Click" />

                        <Separator Margin="0,6,0,14" />

                        <TextBlock Text="DeepSeek 设置" Style="{StaticResource SectionTitle}" />
                        <TextBox x:Name="ModelTextBox" Text="deepseek-v4-flash" />
                        <PasswordBox x:Name="ApiKeyPasswordBox" />
                        <Button Content="保存 AI 设置" Click="SaveSettings_Click" />
                        <Button Content="测试 DeepSeek" Click="TestDeepSeek_Click" />
                        <Button Content="清除本机 Key" Click="ClearApiKey_Click" />
                        <TextBlock x:Name="AiSettingsStatusTextBlock" Text="未配置 API Key 时使用本地规则" Style="{StaticResource MutedText}" Margin="0,0,0,4" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0" Padding="18,9">
            <DockPanel>
                <TextBlock Text="状态" Foreground="{StaticResource Brush.Muted}" FontWeight="SemiBold" Margin="0,0,10,0" />
                <TextBlock x:Name="MainWindowStatus" Text="拖拽文件到窗口，或点击添加文件开始。" Foreground="{StaticResource Brush.Text}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
