<Window x:Class="AiBatchRenamer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 批量重命名" Height="680" Width="1080" MinHeight="560" MinWidth="920"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F6F7F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#D8DDE6" BorderThickness="0,0,0,1" Padding="14">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Content="添加文件" Click="AddFiles_Click" />
                    <Button Content="添加文件夹" Click="AddFolder_Click" />
                    <Button Content="清空" Click="Clear_Click" />
                    <Button Content="撤销上次操作" Click="Undo_Click" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="#566070"
                           Text="{Binding ElementName=MainWindowStatus, Path=Text}" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="FilesGrid" Grid.Column="0" ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      RowHeaderWidth="0" SelectionMode="Extended" Background="#FFFFFF"
                      BorderBrush="#D8DDE6" BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="54" IsReadOnly="True" />
                    <DataGridTextColumn Header="原文件名" Binding="{Binding OriginalName}" Width="2*" IsReadOnly="True" />
                    <DataGridTextColumn Header="新文件名预览" Binding="{Binding ProposedBaseName, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                    <DataGridTextColumn Header="扩展后名称" Binding="{Binding ProposedName}" Width="2*" IsReadOnly="True" />
                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90" IsReadOnly="True" />
                    <DataGridTextColumn Header="说明" Binding="{Binding Message}" Width="180" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1" Margin="12,0,0,0" Background="#FFFFFF" BorderBrush="#D8DDE6"
                    BorderThickness="1" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="重命名模式" FontWeight="SemiBold" />
                        <ComboBox x:Name="ModeComboBox" SelectedIndex="0">
                            <ComboBoxItem Content="自然语言规则" />
                            <ComboBoxItem Content="多名称逐行替换" />
                            <ComboBoxItem Content="查找替换" />
                        </ComboBox>

                        <CheckBox x:Name="SanitizeCheckBox" Content="自动替换非法字符" IsChecked="True" Margin="0,0,0,12" />

                        <TextBlock Text="DeepSeek 设置" FontWeight="SemiBold" />
                        <TextBox x:Name="ModelTextBox" Height="28" Text="deepseek-v4-flash" />
                        <PasswordBox x:Name="ApiKeyPasswordBox" Height="28" Margin="0,4,0,10" />
                        <Button Content="保存 AI 设置" Click="SaveSettings_Click" Margin="0,0,0,12" />
                        <TextBlock x:Name="AiSettingsStatusTextBlock" Text="未配置 API Key 时使用本地规则" Foreground="#566070"
                                   TextWrapping="Wrap" Margin="0,0,0,12" />
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <TextBlock Text="查找替换" FontWeight="SemiBold" />
                        <TextBox x:Name="FindTextBox" Height="28" ToolTip="查找替换模式下使用" />
                        <TextBox x:Name="ReplaceTextBox" Height="28" ToolTip="查找替换模式下使用" />
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="命名要求 / 名称列表" FontWeight="SemiBold" />
                        <TextBox x:Name="InstructionTextBox" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" MinHeight="220"
                                 Text="例如：命名为“项目资料”&#x0a;&#x0a;多名称模式下每行一个新名称" />
                    </StackPanel>

                    <StackPanel Grid.Row="3">
                        <Button Content="生成预览" Click="Preview_Click" Margin="0,0,0,8" />
                        <Button Content="确认重命名" Click="Execute_Click" Margin="0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#D8DDE6" BorderThickness="0,1,0,0" Padding="14,8">
            <TextBlock x:Name="MainWindowStatus" Text="拖拽文件到窗口，或点击添加文件开始。" Foreground="#566070" />
        </Border>
    </Grid>
</Window>
